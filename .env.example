# App Configuration
PORT=3000
SESSION_SECRET=your-secret-key-change-this

# Database Configuration
# Set DB_TYPE to 'sqlite' or 'postgres'
DB_TYPE=sqlite
DB_PATH=database.sqlite

# Supabase / PostgreSQL Configuration (if DB_TYPE=postgres)
# Example: postgres://postgres.yourproject:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=your-supabase-connection-string

# School Info
SCHOOL_NAME="Nexus SIS"
