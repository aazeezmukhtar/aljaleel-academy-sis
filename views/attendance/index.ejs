<%- include('../partials/header') %>

    <div class="dashboard-container">
        <%- include('../partials/sidebar') %>

            <main class="main-content">
                <header class="content-header" style="margin-bottom: 30px;">
                    <div>
                        <h1>Attendance Management</h1>
                        <p>Track daily student attendance and regularity.</p>
                    </div>
                    <a href="/attendance/report" class="btn btn-outline">View Reports</a>
                </header>

                <section style="max-width: 600px; margin: 0 auto;">
                    <div class="card">
                        <h3>Take Student Attendance</h3>
                        <p style="margin-bottom: 20px; color: var(--text-muted);">Select a class and date to start
                            marking attendance.</p>

                        <form action="/attendance/take" method="GET" class="enroll-form">
                            <div class="form-group">
                                <label>Select Class</label>
                                <% if (typeof classes !== 'undefined' && classes && classes.length > 0) { %>
                                <select name="class_id" required class="form-control">
                                    <option value="">-- Choose Class --</option>
                                    <% classes.forEach(c=> { %>
                                        <option value="<%= c.id %>">
                                            <%= c.name %>
                                        </option>
                                        <% }); %>
                                </select>
                                <% } else { %>
                                <div class="emp-state" style="padding: 10px; border: 1px dashed #ef4444; color: #ef4444; border-radius: 8px;">
                                    <i class="bi bi-exclamation-triangle"></i> No classes assigned to you.
                                </div>
                                <% } %>
                            </div>
                            <div class="form-group">
                                <label>Date</label>
                                <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>"
                                    required class="form-control">
                            </div>
                            <button type="submit" class="btn" style="width: 100%; margin-top: 10px;">Start
                                Marking</button>
                        </form>
                    </div>

                </section>
            </main>
    </div>

    <%- include('../partials/footer') %>