<%- include('partials/header') %>

    <div class="dashboard-container">
        <%- include('partials/sidebar') %>

            <!-- Main Content -->
            <main class="main-content">
                <header class="content-header">
                    <div>
                        <h1>Welcome, <%= user.first_name %>
                        </h1>
                        <p class="text-muted">Staff Dashboard | <%= new Date().toLocaleDateString('en-US', {
                                weekday: 'long' , year: 'numeric' , month: 'long' , day: 'numeric' }) %>
                        </p>
                    </div>
                    <div class="header-actions">
                        <div class="notification-bell-container" onclick="toggleNotificationDropdown(event)" style="background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99, 102, 241, 0.2); border-radius: 12px; padding: 10px;">
                            <i class="bi bi-bell-fill" style="color: #6366f1; font-size: 1.4rem;"></i>
                            <span class="notification-badge">0</span>
                            <div class="notification-dropdown">
                                <div class="notification-header">
                                    <strong>Notifications</strong>
                                    <span class="text-muted">Recent Updates</span>
                                </div>
                                <div class="notification-list"></div>
                            </div>
                        </div>
                        <span class="badge badge-primary">
                            <%= user.role %>
                        </span>
                    </div>
                </header>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #6366f1, #4f46e5);">
                            <i class="bi bi-door-open-fill"></i>
                        </div>
                        <div class="stat-content">
                            <h3>
                                <%= stats.assignedClasses %>
                            </h3>
                            <p>Assigned Classes</p>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #059669);">
                            <i class="bi bi-book-fill"></i>
                        </div>
                        <div class="stat-content">
                            <h3>
                                <%= stats.assignedSubjects %>
                            </h3>
                            <p>Assigned Subjects</p>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div class="stat-content">
                            <h3>
                                <%= stats.myStudents %>
                            </h3>
                            <p>Total Students</p>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #ec4899, #db2777);">
                            <i class="bi bi-calendar-check-fill"></i>
                        </div>
                        <div class="stat-content">
                            <h3>
                                <%= stats.attendanceToday %>
                            </h3>
                            <p>Attendance Today</p>
                        </div>
                    </div>
                </div>

                <div class="grid-3" style="margin-top: 40px;">
                    <!-- Assigned Classes -->
                    <div class="card">
                        <div class="card-header"
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <h3>My Classes</h3>
                            <a href="/attendance" class="btn btn-sm btn-outline">Take Attendance</a>
                        </div>
                        <div class="list-group">
                            <% if (assignedClasses && assignedClasses.length> 0) { %>
                                <% assignedClasses.forEach(cls=> { %>
                                    <div class="list-item"
                                        style="padding: 15px 0; border-bottom: 1px solid #eee; display: flex; align-items: center; justify-content: space-between;">
                                        <div>
                                            <strong style="font-size: 1.1rem;">
                                                <%= cls.name %>
                                            </strong>
                                            <p class="text-muted" style="font-size: 0.85rem; margin: 0;">Class Teacher
                                            </p>
                                        </div>
                                        <i class="bi bi-chevron-right text-muted"></i>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <p class="text-muted" style="padding: 20px; text-align: center;">No classes
                                                assigned yet.</p>
                                            <% } %>
                        </div>
                    </div>

                    <!-- Assigned Subjects -->
                    <div class="card">
                        <div class="card-header"
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <h3>My Subjects</h3>
                            <a href="/results" class="btn btn-sm btn-outline">Enter Results</a>
                        </div>
                        <div class="list-group">
                            <% if (assignedSubjects && assignedSubjects.length> 0) { %>
                                <% assignedSubjects.forEach(sub=> { %>
                                    <div class="list-item"
                                        style="padding: 15px 0; border-bottom: 1px solid #eee; display: flex; align-items: center; justify-content: space-between;">
                                        <div>
                                            <strong style="font-size: 1.1rem;">
                                                <%= sub.name %>
                                            </strong>
                                            <p class="text-muted" style="font-size: 0.85rem; margin: 0;">
                                                <%= sub.class_name %>
                                            </p>
                                        </div>
                                        <i class="bi bi-chevron-right text-muted"></i>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <p class="text-muted" style="padding: 20px; text-align: center;">No subjects
                                                assigned yet.</p>
                                            <% } %>
                        </div>
                    </div>

