                    <h1>Subject Analysis</h1>
                </div>
                <div class="header-actions">
                    <button class="btn btn-primary btn-export" data-filename="subject_analysis.csv">
                        <i class="bi bi-file-earmark-spreadsheet"></i> Export CSV
                    </button>
                    <button onclick="window.print()" class="btn btn-secondary">
                        <i class="bi bi-printer"></i> Print Report
                    </button>
                </div>
            </header>

            <div class="card no-print settings-card">
                <form action="/reports/academic/analysis" method="GET" class="filter-form">
