            <header class="content-header no-print">
                <div class="header-left">
                    <a href="/reports/academic" class="back-link"><i class="bi bi-arrow-left"></i> Back</a>
                    <h1>Master Broadsheet</h1>
                </div>
                <div class="header-actions">
                    <button class="btn btn-primary btn-export" data-filename="broadsheet.csv">
                        <i class="bi bi-file-earmark-spreadsheet"></i> Export CSV
                    </button>
                    <button onclick="window.print()" class="btn btn-secondary">
                        <i class="bi bi-printer"></i> Print Sheet
                    </button>
                </div>
            </header>

            <div class="card no-print settings-card">
