<%- include('../partials/header') %>
    <%- include('../partials/sidebar') %>

        <main class="main-content">
            <header class="content-header">
                <h1>Report Center</h1>
                <p>Comprehensive insights and analytical reports.</p>
            </header>

            <div class="report-dashboard-grid">
                <!-- Academic Reports -->
                <a href="/reports/academic" class="report-card">
                    <div class="report-icon academic">
                        <i class="bi bi-mortarboard-fill"></i>
                    </div>
                    <div class="report-info">
                        <h3>Academic & Results</h3>
                        <p>Broadsheets, Master Sheets, Trend Analysis, and Report Cards.</p>
                    </div>
                </a>

                <!-- Student Reports -->
                <a href="/reports/students" class="report-card">
                    <div class="report-icon student">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="report-info">
                        <h3>Student Demographics</h3>
                        <p>Class Lists, Gender Stats, Admission Rates, and Profile Audits.</p>
                    </div>
                </a>

                <!-- Attendance Reports -->
                <a href="/reports/attendance" class="report-card">
                    <div class="report-icon attendance">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                    <div class="report-info">
                        <h3>Attendance & Registers</h3>
                        <p>Daily Registers, Monthly Summaries, and Low Attendance Alerts.</p>
                    </div>
                </a>

                <!-- Finance Reports -->
                <% if (user.role==='Admin' || user.role==='Bursar' ) { %>
                    <a href="/reports/fees" class="report-card">
                        <div class="report-icon finance">
                            <i class="bi bi-wallet-fill"></i>
                        </div>
                        <div class="report-info">
                            <h3>Finance & Fees</h3>
                            <p>Fee Status, Debtors Lists, Collections, and Receipt History.</p>
                        </div>
                    </a>
                    <% } %>

                        <!-- Staff Reports -->
                        <% if (user.role==='Admin' ) { %>
                            <a href="/reports/staff" class="report-card">
                                <div class="report-icon staff">
                                    <i class="bi bi-person-badge-fill"></i>
                                </div>
                                <div class="report-info">
                                    <h3>Staff & HR</h3>
                                    <p>Staff Directory, Workload Analysis, and Activity Logs.</p>
                                </div>
                            </a>
                            <% } %>

                                <!-- Health Reports -->
                                <a href="/reports/health" class="report-card">
                                    <div class="report-icon health">
                                        <i class="bi bi-heart-pulse-fill"></i>
                                    </div>
                                    <div class="report-info">
                                        <h3>Health & Wellness</h3>
                                        <p>Medical Alerts, Emergency Contacts, and Health Stats.</p>
                                    </div>
                                </a>

                                <!-- System Audit -->
                                <% if (user.role==='Admin' ) { %>
                                    <a href="/reports/audit" class="report-card">
                                        <div class="report-icon audit">
                                            <i class="bi bi-shield-lock-fill"></i>
                                        </div>
                                        <div class="report-info">
                                            <h3>System Management</h3>
                                            <p>System Audit Logs, Access Control, and Security Events.</p>
                                        </div>
                                    </a>
                                    <% } %>
            </div>
        </main>

        <style>
            .report-dashboard-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 20px;
                margin-top: 20px;
            }

            .report-card {
                background: white;
                border-radius: 12px;
                padding: 25px;
                display: flex;
                align-items: center;
                gap: 20px;
                text-decoration: none;
                color: inherit;
                border: 1px solid #eee;
                transition: transform 0.2s, box-shadow 0.2s;
            }

            .report-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
                border-color: var(--primary);
            }

            .report-icon {
                width: 60px;
                height: 60px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.8rem;
            }

            .report-icon.academic {
                background: #e0f2fe;
                color: #0284c7;
            }

            .report-icon.student {
                background: #fce7f3;
                color: #db2777;
            }

            .report-icon.attendance {
                background: #dcfce7;
                color: #16a34a;
            }

            .report-icon.finance {
                background: #fff7ed;
                color: #ea580c;
            }

            .report-icon.staff {
                background: #f3e8ff;
                color: #9333ea;
            }

            .report-icon.health {
                background: #fee2e2;
                color: #dc2626;
            }

            .report-icon.audit {
                background: #f1f5f9;
                color: #475569;
            }

            .report-info h3 {
                margin: 0 0 5px 0;
                font-size: 1.1rem;
                color: var(--text-dark);
            }

            .report-info p {
                margin: 0;
                font-size: 0.85rem;
                color: var(--text-muted);
                line-height: 1.4;
            }
        </style>

        <%- include('../partials/footer') %>