                            <hr style="margin: 15px 0; opacity: 0.1;">
                            <p class="text-muted" style="font-size: 0.85rem;">
                                <i class="bi bi-info-circle"></i> Results entered here are subject to administrator
                                approval before they appear on student report cards.
                            </p>
                        </div>
                    </div>
                </div>
            </main>
    </div>

    <style>
        .report-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .report-card-link {
            text-decoration: none;
            color: inherit;
            transition: transform 0.2s;
        }

        .report-card-link:hover {
            transform: translateY(-3px);
        }

        .stat-card {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 25px !important;
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
        }

        .stat-info h3 {
            margin: 0 0 5px 0;
            font-size: 1.1rem;
        }

        .stat-info p {
            margin: 0;
            font-size: 0.85rem;
            color: #64748b;
            line-height: 1.4;
        }
    </style>

    <%- include('../partials/footer') %>