<%- include('../partials/header') %>
    <div class="dashboard-container">
        <%- include('../partials/sidebar') %>
            <main class="main-content">
                <header class="content-header">
                    <div>
                        <h1>Result Configuration</h1>
                        <p>Configure assessment weights globally, per-section, and manage the grading system scale.</p>
                    </div>
                </header>

                <div style="display: flex; flex-direction: column; gap: 20px;">
                    <!-- Configuration Tabs -->
                    <div class="tabs-navigation" style="display: flex; gap: 10px; border-bottom: 2px solid var(--border-color, #e2e8f0); padding-bottom: 10px;">
                        <button class="btn btn-secondary tab-btn active" onclick="switchTab('global-weights')">Global Weights</button>
                        <button class="btn btn-secondary tab-btn" onclick="switchTab('section-weights')">Section-Based Weights</button>
                        <button class="btn btn-secondary tab-btn" onclick="switchTab('grading-system')">Grading Scale</button>
                    </div>

                    <!-- Tab 1: Global Weights -->
                    <div id="global-weights" class="tab-content card active-tab">
                        <h3>Global Assessment Weights</h3>
                        <p class="text-muted">Define the default/fallback maximum obtainable scores for each assessment.</p>
                        <form id="configForm" style="margin-top: 15px;">
                            <div class="form-group">
                                <label>Number of CAs</label>
                                <select name="ca_count" class="form-control" onchange="toggleCA2(this.value)">
                                    <option value="1" <%=(config.ca_count==1 || config.ca_count=='1' ) ? 'selected' : '' %>>1 CA Only</option>
                                    <option value="2" <%=(config.ca_count==2 || config.ca_count !='1' ) ? 'selected' : '' %>>2 CAs</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>CA 1 Max Score</label>
                                <input type="number" name="ca1_max" class="form-control" value="<%= config.ca1_max || 20 %>" required min="0" max="100">
                            </div>
                            <div class="form-group" id="ca2Group">
                                <label>CA 2 Max Score</label>
                                <input type="number" name="ca2_max" class="form-control" value="<%= config.ca2_max || 20 %>" required min="0" max="100">
                            </div>
                            <div class="form-group">
                                <label>Exam Max Score</label>
                                <input type="number" name="exam_max" class="form-control" value="<%= config.exam_max || 60 %>" required min="0" max="100">
                            </div>
                            <div class="alert alert-info" style="margin-top: 15px;">
                                <strong>Total:</strong> <span id="totalScore">100</span>%
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%;">Save Global Weights</button>
                        </form>
                    </div>

                    <!-- Tab 2: Section-Based Weights -->
                    <div id="section-weights" class="tab-content tab-hidden">
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px;">
                            <% if (typeof sections !== 'undefined' && sections && sections.length > 0) { %>
                                <% sections.forEach(sec => { 
                                    const secCfg = (typeof sectionConfigs !== 'undefined' && sectionConfigs) 
                                        ? sectionConfigs.find(c => c.section_id === sec.id) || { ca_count: 2, ca1_max: 20, ca2_max: 20, exam_max: 60 }
                                        : { ca_count: 2, ca1_max: 20, ca2_max: 20, exam_max: 60 };
                                %>
                                    <div class="card">
                                        <h3 style="display: flex; align-items: center; gap: 8px;">
                                            <i class="bi bi-diagram-3-fill text-primary"></i>
                                            <%= sec.name %> Section
                                        </h3>
                                        <p class="text-muted">Configure weight limits specifically for classes in the <%= sec.name %> section.</p>
                                        
                                        <form class="section-config-form" data-section-id="<%= sec.id %>" style="margin-top: 15px;">
                                            <input type="hidden" name="section_id" value="<%= sec.id %>">
                                            <div class="form-group">
                                                <label>Number of CAs</label>
                                                <select name="ca_count" class="form-control" onchange="toggleSectionCA2('<%= sec.id %>', this.value)">
                                                    <option value="1" <%= secCfg.ca_count == 1 ? 'selected' : '' %>>1 CA Only</option>
                                                    <option value="2" <%= secCfg.ca_count == 2 ? 'selected' : '' %>>2 CAs</option>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label>CA 1 Max Score</label>
                                                <input type="number" name="ca1_max" class="form-control" value="<%= secCfg.ca1_max %>" required min="0" max="100" oninput="calcSectionTotal('<%= sec.id %>')">
                                            </div>
                                            <div class="form-group" id="ca2Group_<%= sec.id %>">
                                                <label>CA 2 Max Score</label>
                                                <input type="number" name="ca2_max" class="form-control" value="<%= secCfg.ca2_max %>" required min="0" max="100" oninput="calcSectionTotal('<%= sec.id %>')">
                                            </div>
                                            <div class="form-group">
                                                <label>Exam Max Score</label>
                                                <input type="number" name="exam_max" class="form-control" value="<%= secCfg.exam_max %>" required min="0" max="100" oninput="calcSectionTotal('<%= sec.id %>')">
                                            </div>
                                            <div class="alert alert-info" style="margin-top: 15px;">
                                                <strong>Total:</strong> <span id="totalScore_<%= sec.id %>">100</span>%
                                            </div>
                                            <button type="submit" class="btn btn-primary" style="width: 100%;">Save <%= sec.name %> Weights</button>
                                        </form>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 40px;">
                                    <i class="bi bi-info-circle" style="font-size: 3rem; color: var(--text-muted);"></i>
                                    <p style="margin-top: 15px;">No academic sections defined yet. Run system migrations or seed database first.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Tab 3: Grading System Scale -->
                    <div id="grading-system" class="tab-content card tab-hidden">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <div>
                                <h3>Grading System Scale</h3>
                                <p class="text-muted">Define the letter grades and score ranges.</p>
                            </div>
                            <button type="button" class="btn btn-secondary btn-sm" onclick="addNewGradeRow()"><i class="bi bi-plus-circle"></i> Add Row</button>
                        </div>
                        
                        <form id="gradingForm">
                            <table class="table" style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr>
                                        <th>Grade</th>
                                        <th>Min Score</th>
                                        <th>Max Score</th>
                                        <th>Remark</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="gradingTableBody">
                                    <% if (typeof grading !== 'undefined' && grading && grading.length > 0) { %>
                                        <% grading.forEach(g => { %>
                                            <tr data-id="<%= g.id %>">
                                                <td><input type="text" name="grade" class="form-control" value="<%= g.grade %>" required style="width: 80px;"></td>
                                                <td><input type="number" name="min_score" class="form-control" value="<%= g.min_score %>" required min="0" max="100" style="width: 100px;"></td>
                                                <td><input type="number" name="max_score" class="form-control" value="<%= g.max_score %>" required min="0" max="100" style="width: 100px;"></td>
                                                <td><input type="text" name="remark" class="form-control" value="<%= g.remark %>" required></td>
                                                <td>
                                                    <button type="button" class="btn btn-danger btn-sm" onclick="deleteGradeRow(this)" style="padding: 5px 10px;"><i class="bi bi-trash"></i></button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr class="no-grades-row">
                                            <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 20px;">No grading rows defined. Add one above!</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 20px;">Save Grading Scale</button>
                        </form>
                    </div>
                </div>
            </main>
    </div>

    <style>
        .tab-hidden {
            display: none !important;
        }
        .active-tab {
            display: block !important;
        }
        .tab-btn.active {
            background-color: var(--primary-color, #4f46e5);
            color: #fff;
            border-color: var(--primary-color, #4f46e5);
        }
    </style>

    <script>
        // Tab switching logic
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('tab-hidden'));
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active-tab'));
            
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            
            const targetContent = document.getElementById(tabId);
            if (targetContent) {
                targetContent.classList.remove('tab-hidden');
                targetContent.classList.add('active-tab');
            }
            
            event.currentTarget.classList.add('active');
        }

        // Global Weights Toggle & Calculation
        const ca2Group = document.getElementById('ca2Group');
        const ca2Input = document.querySelector('[name="ca2_max"]');
        const totalSpan = document.getElementById('totalScore');

        function toggleCA2(val) {
            if (val == 1) {
                ca2Group.style.display = 'none';
                ca2Input.value = 0;
            } else {
                ca2Group.style.display = 'block';
            }
            calcTotal();
        }

        function calcTotal() {
            let sum = 0;
            sum += (parseFloat(document.querySelector('[name="ca1_max"]').value) || 0);
            if (document.querySelector('[name="ca_count"]').value == 2) {
                sum += (parseFloat(document.querySelector('[name="ca2_max"]').value) || 0);
            }
            sum += (parseFloat(document.querySelector('[name="exam_max"]').value) || 0);

            totalSpan.textContent = sum;
            if (sum !== 100) totalSpan.style.color = 'red';
            else totalSpan.style.color = 'green';
        }

        // Listen for global form changes
        document.querySelectorAll('#configForm input').forEach(input => input.addEventListener('input', calcTotal));
        toggleCA2(document.querySelector('[name="ca_count"]').value);

        // Section-based weight management
        function toggleSectionCA2(secId, val) {
            const grp = document.getElementById('ca2Group_' + secId);
            const inp = grp ? grp.querySelector('input') : null;
            if (grp && inp) {
                if (val == 1) {
                    grp.style.display = 'none';
                    inp.value = 0;
                } else {
                    grp.style.display = 'block';
                }
            }
            calcSectionTotal(secId);
        }

        function calcSectionTotal(secId) {
            const form = document.querySelector(`form[data-section-id="${secId}"]`);
            if (!form) return;
            const caCount = form.ca_count.value;
            const ca1 = parseFloat(form.ca1_max.value) || 0;
            const ca2 = caCount == 2 ? (parseFloat(form.ca2_max.value) || 0) : 0;
            const exam = parseFloat(form.exam_max.value) || 0;
            
            const totalSpan = document.getElementById('totalScore_' + secId);
            if (totalSpan) {
                const sum = ca1 + ca2 + exam;
                totalSpan.textContent = sum;
                if (sum !== 100) totalSpan.style.color = 'red';
                else totalSpan.style.color = 'green';
            }
        }

        // Initialize section config totals & visibility on load
        document.querySelectorAll('.section-config-form').forEach(form => {
            const secId = form.getAttribute('data-section-id');
            toggleSectionCA2(secId, form.ca_count.value);
        });

        // Grading Scale Addition / Deletion
        function addNewGradeRow() {
            const tbody = document.getElementById('gradingTableBody');
            const noRow = tbody.querySelector('.no-grades-row');
            if (noRow) noRow.remove();

            const tr = document.createElement('tr');
            tr.setAttribute('data-id', '');
            tr.innerHTML = `
                <td><input type="text" name="grade" class="form-control" placeholder="A" required style="width: 80px;"></td>
                <td><input type="number" name="min_score" class="form-control" placeholder="70" required min="0" max="100" style="width: 100px;"></td>
                <td><input type="number" name="max_score" class="form-control" placeholder="100" required min="0" max="100" style="width: 100px;"></td>
                <td><input type="text" name="remark" class="form-control" placeholder="Excellent" required></td>
                <td>
                    <button type="button" class="btn btn-danger btn-sm" onclick="deleteGradeRow(this)" style="padding: 5px 10px;"><i class="bi bi-trash"></i></button>
                </td>
            `;
            tbody.appendChild(tr);
        }

        function deleteGradeRow(btn) {
            const tr = btn.closest('tr');
            const id = tr.getAttribute('data-id');
            if (id) {
                tr.setAttribute('data-deleted', 'true');
                tr.style.display = 'none';
            } else {
                tr.remove();
            }
            
            const tbody = document.getElementById('gradingTableBody');
            if (tbody.querySelectorAll('tr:not([style*="display: none"])').length === 0) {
                tbody.innerHTML = `
                    <tr class="no-grades-row">
                        <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 20px;">No grading rows defined. Add one above!</td>
                    </tr>
                `;
            }
        }

        // Global Config Form Submit
        document.getElementById('configForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = {
                ca_count: e.target.ca_count.value,
                ca1_max: e.target.ca1_max.value,
                ca2_max: e.target.ca2_max.value,
                exam_max: e.target.exam_max.value
            };
            try {
                const res = await fetch('/results/setup/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                const data = await res.json();
                if (data.success) alert('Global configuration saved successfully!');
                else alert('Error: ' + data.message);
            } catch (err) {
                console.error(err);
                alert('Failed to save configuration.');
            }
        });

        // Section Config Forms Submit
        document.querySelectorAll('.section-config-form').forEach(form => {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = {
                    section_id: e.target.section_id.value,
                    ca_count: e.target.ca_count.value,
                    ca1_max: e.target.ca1_max.value,
                    ca2_max: e.target.ca2_max.value,
                    exam_max: e.target.exam_max.value
                };
                try {
                    const res = await fetch('/results/setup/section-config', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    });
                    const data = await res.json();
                    if (data.success) alert('Section weights saved successfully!');
                    else alert('Error: ' + data.message);
                } catch (err) {
                    console.error(err);
                    alert('Failed to save section configuration.');
                }
            });
        });

        // Grading Scale Form Submit
        document.getElementById('gradingForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const grades = [];
            const rows = document.querySelectorAll('#gradingTableBody tr');
            
            rows.forEach(row => {
                if (row.classList.contains('no-grades-row')) return;
                const id = row.getAttribute('data-id');
                const deleted = row.getAttribute('data-deleted') === 'true';
                
                if (deleted) {
                    grades.push({ id, deleted: true });
                } else {
                    grades.push({
                        id: id || undefined,
                        grade: row.querySelector('[name="grade"]').value,
                        min: row.querySelector('[name="min_score"]').value,
                        max: row.querySelector('[name="max_score"]').value,
                        remark: row.querySelector('[name="remark"]').value
                    });
                }
            });

            try {
                const res = await fetch('/results/setup/grading', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ grades })
                });
                const data = await res.json();
                if (data.success) {
                    alert('Grading scale updated successfully!');
                    window.location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                console.error(err);
                alert('Failed to save grading scale.');
            }
        });
    </script>
    <%- include('../partials/footer') %>