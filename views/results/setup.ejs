<%- include('../partials/header') %>
    <div class="dashboard-container">
        <%- include('../partials/sidebar') %>
            <main class="main-content">
                <header class="content-header">
                    <div>
                        <h1>Result Configuration</h1>
                        <p>Configure assessment weights (CA1, CA2, Exam).</p>
                    </div>
                </header>

                <div style="display: flex; flex-direction: column; gap: 30px;">
                    <!-- Assessment Configuration -->
                    <div class="card">
                        <h3>Assessment Weights</h3>
                        <p class="text-muted">Define maximum obtainable scores for each assessment.</p>
                        <form id="configForm">
                            <div class="form-group">
                                <label>Number of CAs</label>
                                <select name="ca_count" class="form-control" onchange="toggleCA2(this.value)">
                                    <option value="1" <%=(config.ca_count==1 || config.ca_count=='1' ) ? 'selected' : ''
                                        %>>1 CA Only</option>
                                    <option value="2" <%=(config.ca_count==2 || config.ca_count !='1' ) ? 'selected'
                                        : '' %>>2 CAs</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>CA 1 Max Score</label>
                                <input type="number" name="ca1_max" class="form-control"
                                    value="<%= config.ca1_max || 20 %>" required min="0" max="100">
                            </div>
                            <div class="form-group" id="ca2Group">
                                <label>CA 2 Max Score</label>
                                <input type="number" name="ca2_max" class="form-control"
                                    value="<%= config.ca2_max || 20 %>" required min="0" max="100">
                            </div>
                            <div class="form-group">
                                <label>Exam Max Score</label>
                                <input type="number" name="exam_max" class="form-control"
                                    value="<%= config.exam_max || 60 %>" required min="0" max="100">
                            </div>
                            <div class="alert alert-info" style="margin-top: 15px;">
                                <strong>Total:</strong> <span id="totalScore">100</span>%
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%;">Save Weights</button>
                        </form>
                    </div>
                </div>
            </main>
    </div>

    <script>
        // Auto-calculate Total
        const inputs = document.querySelectorAll('#configForm input');
        const totalSpan = document.getElementById('totalScore');
        const ca2Group = document.getElementById('ca2Group');
        const ca2Input = document.querySelector('[name="ca2_max"]');

        function toggleCA2(val) {
            if (val == 1) {
                ca2Group.style.display = 'none';
                ca2Input.value = 0;
            } else {
                ca2Group.style.display = 'block';
            }
            calcTotal();
        }

        // Initialize display based on loaded value
        toggleCA2(document.querySelector('[name="ca_count"]').value);

        function calcTotal() {
            let sum = 0;
            // Only sum inputs that are visible/active logic
            sum += (parseFloat(document.querySelector('[name="ca1_max"]').value) || 0);

            if (document.querySelector('[name="ca_count"]').value == 2) {
                sum += (parseFloat(document.querySelector('[name="ca2_max"]').value) || 0);
            }

            sum += (parseFloat(document.querySelector('[name="exam_max"]').value) || 0);

            totalSpan.textContent = sum;
            if (sum !== 100) totalSpan.style.color = 'red';
            else totalSpan.style.color = 'green';
        }

        calcTotal();
        inputs.forEach(i => i.addEventListener('input', calcTotal));

        // Config Save
        document.getElementById('configForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = {
                ca_count: e.target.ca_count.value,
                ca1_max: e.target.ca1_max.value,
                ca2_max: e.target.ca2_max.value,
                exam_max: e.target.exam_max.value
            };
            try {
                const res = await fetch('/results/setup/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                const data = await res.json();
                if (data.success) {
                    alert('Configuration Saved Successfully!');
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                console.error(err);
                alert('Failed to save configuration. Check console for details.');
            }
        });
    </script>
    <%- include('../partials/footer') %>