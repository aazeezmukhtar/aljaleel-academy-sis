<%- include('../partials/header') %>
    <div class="dashboard-container">
        <%- include('../partials/sidebar') %>
            <main class="main-content">
                <header class="content-header">
                    <div>
                        <h1>Result Configuration</h1>
                        <p>Configure assessment weights per section (CA1, CA2, Exam).</p>
                    </div>
                </header>

                <div style="display: flex; flex-direction: column; gap: 30px;">

                    <!-- ── Global Default Config ─────────────────────────── -->
                    <div class="card">
                        <h3><i class="bi bi-sliders"></i> Global Default Weights</h3>
                        <p class="text-muted" style="font-size: 0.85rem; margin-bottom: 20px;">
                            This is the fallback used when a section does not have its own config.
                        </p>
                        <form id="configForm">
                            <div class="form-group">
                                <label>Number of CAs</label>
                                <select name="ca_count" class="form-control" onchange="toggleCA2Global(this.value)">
                                    <option value="1" <%=(config.ca_count==1 || config.ca_count=='1') ? 'selected' : '' %>>1 CA Only</option>
                                    <option value="2" <%=(config.ca_count==2 || config.ca_count=='2' || !config.ca_count) ? 'selected' : '' %>>2 CAs</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>CA 1 Max Score</label>
                                <input type="number" name="ca1_max" class="form-control" value="<%= config.ca1_max || 20 %>" required min="0" max="100">
                            </div>
                            <div class="form-group" id="ca2GroupGlobal">
                                <label>CA 2 Max Score</label>
                                <input type="number" name="ca2_max" class="form-control" value="<%= config.ca2_max || 20 %>" required min="0" max="100">
                            </div>
                            <div class="form-group">
                                <label>Exam Max Score</label>
                                <input type="number" name="exam_max" class="form-control" value="<%= config.exam_max || 60 %>" required min="0" max="100">
                            </div>
                            <div style="padding: 10px 15px; background: #f8fafc; border-radius: 8px; margin-top: 10px; font-size: 0.9rem;">
                                <strong>Total:</strong> <span id="globalTotal" style="font-weight: 800;">100</span>/100
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 16px;">Save Global Default</button>
                        </form>
                    </div>

                    <!-- ── Per-Section Config Cards ──────────────────────── -->
                    <% sections.forEach(sec => { %>
                        <% const sc = sectionConfigs[sec.id] || {}; %>
                        <div class="card" id="secCard-<%= sec.id %>">
                            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                                <span style="background: <%= sec.name === 'Academy' ? '#e0e7ff' : '#fef3c7' %>; color: <%= sec.name === 'Academy' ? '#4338ca' : '#92400e' %>; padding: 4px 14px; border-radius: 20px; font-weight: 700; font-size: 0.85rem;">
                                    <%= sec.name %>
                                </span>
                                <h3 style="margin: 0; font-size: 1rem;">Section Result Weights</h3>
                            </div>
                            <p class="text-muted" style="font-size: 0.82rem; margin-bottom: 20px;">
                                Overrides the global default for all classes in the <strong><%= sec.name %></strong> section.
                            </p>
                            <form class="section-config-form" data-section-id="<%= sec.id %>">
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                                    <div class="form-group">
                                        <label>Number of CAs</label>
                                        <select name="ca_count" class="form-control" onchange="toggleCA2Sec(this, '<%= sec.id %>')">
                                            <option value="1" <%= (sc.ca_count == '1') ? 'selected' : '' %>>1 CA Only</option>
                                            <option value="2" <%= (sc.ca_count != '1') ? 'selected' : '' %>>2 CAs</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label>CA 1 Max</label>
                                        <input type="number" name="ca1_max" class="form-control sec-input" value="<%= sc.ca1_max || 20 %>" min="0" max="100">
                                    </div>
                                    <div class="form-group sec-ca2-<%= sec.id %>" <%= (sc.ca_count == '1') ? 'style="display:none"' : '' %>>
                                        <label>CA 2 Max</label>
                                        <input type="number" name="ca2_max" class="form-control sec-input" value="<%= sc.ca2_max || 20 %>" min="0" max="100">
                                    </div>
                                    <div class="form-group">
                                        <label>Exam Max</label>
                                        <input type="number" name="exam_max" class="form-control sec-input" value="<%= sc.exam_max || 60 %>" min="0" max="100">
                                    </div>
                                </div>
                                <div style="padding: 10px 15px; background: #f8fafc; border-radius: 8px; margin-top: 8px; font-size: 0.9rem;">
                                    <strong>Total:</strong> <span class="sec-total" data-sec="<%= sec.id %>" style="font-weight: 800;"><%= (parseInt(sc.ca1_max)||20) + (sc.ca_count != '1' ? (parseInt(sc.ca2_max)||20) : 0) + (parseInt(sc.exam_max)||60) %></span>/100
                                </div>
                                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 16px;">
                                    <i class="bi bi-check-circle"></i> Save <%= sec.name %> Config
                                </button>
                            </form>
                        </div>
                    <% }) %>

                </div>
            </main>
    </div>

    <script>
        // ── Global Config Form ─────────────────────────────────────────────
        const globalInputs = document.querySelectorAll('#configForm input');
        const globalTotal = document.getElementById('globalTotal');
        const ca2GroupGlobal = document.getElementById('ca2GroupGlobal');

        function toggleCA2Global(val) {
            if (val == 1) {
                ca2GroupGlobal.style.display = 'none';
                ca2GroupGlobal.querySelector('input').value = 0;
            } else {
                ca2GroupGlobal.style.display = 'block';
            }
            calcGlobalTotal();
        }

        function calcGlobalTotal() {
            const ca_count = document.querySelector('#configForm [name="ca_count"]').value;
            let sum = parseFloat(document.querySelector('#configForm [name="ca1_max"]').value) || 0;
            if (ca_count == 2) sum += parseFloat(document.querySelector('#configForm [name="ca2_max"]').value) || 0;
            sum += parseFloat(document.querySelector('#configForm [name="exam_max"]').value) || 0;
            globalTotal.textContent = sum;
            globalTotal.style.color = sum === 100 ? 'green' : 'red';
        }

        toggleCA2Global(document.querySelector('#configForm [name="ca_count"]').value);
        globalInputs.forEach(i => i.addEventListener('input', calcGlobalTotal));

        document.getElementById('configForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const fd = new FormData(e.target);
            const data = Object.fromEntries(fd.entries());
            const res = await fetch('/results/setup/config', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data)
            });
            const json = await res.json();
            alert(json.success ? 'Global config saved!' : 'Error: ' + json.message);
        });

        // ── Section Config Forms ───────────────────────────────────────────
        function toggleCA2Sec(select, secId) {
            const ca2Group = document.querySelector('.sec-ca2-' + secId);
            const ca2Input = ca2Group ? ca2Group.querySelector('input') : null;
            if (select.value == 1) {
                if (ca2Group) ca2Group.style.display = 'none';
                if (ca2Input) ca2Input.value = 0;
            } else {
                if (ca2Group) ca2Group.style.display = 'block';
            }
            calcSecTotal(secId);
        }

        function calcSecTotal(secId) {
            const form = document.querySelector('.section-config-form[data-section-id="' + secId + '"]');
            if (!form) return;
            const ca_count = form.querySelector('[name="ca_count"]').value;
            let sum = parseFloat(form.querySelector('[name="ca1_max"]').value) || 0;
            if (ca_count == 2) sum += parseFloat(form.querySelector('[name="ca2_max"]').value) || 0;
            sum += parseFloat(form.querySelector('[name="exam_max"]').value) || 0;
            const totalEl = form.querySelector('.sec-total');
            if (totalEl) {
                totalEl.textContent = sum;
                totalEl.style.color = sum === 100 ? 'green' : 'red';
            }
        }

        document.querySelectorAll('.section-config-form').forEach(form => {
            const secId = form.dataset.sectionId;

            // Attach input listeners for live total
            form.querySelectorAll('.sec-input').forEach(inp => {
                inp.addEventListener('input', () => calcSecTotal(secId));
            });

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const fd = new FormData(form);
                const data = Object.fromEntries(fd.entries());
                data.section_id = secId;
                const btn = form.querySelector('button[type="submit"]');
                btn.disabled = true;
                btn.textContent = 'Saving...';
                try {
                    const res = await fetch('/results/setup/section-config', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data)
                    });
                    const json = await res.json();
                    btn.textContent = json.success ? '✓ Saved!' : '✗ Failed';
                    btn.style.background = json.success ? '#10b981' : '#ef4444';
                    setTimeout(() => { btn.textContent = 'Save Config'; btn.disabled = false; btn.style.background = ''; }, 2500);
                } catch (err) {
                    btn.textContent = '✗ Network Error';
                    btn.disabled = false;
                }
            });
        });
    </script>
<%- include('../partials/footer') %>