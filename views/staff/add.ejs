<%- include('../partials/header') %>

    <div class="dashboard-container">
        <%- include('../partials/sidebar') %>

            <main class="main-content">
                <header style="margin-bottom: 30px;">
                    <a href="/staff" style="color: var(--primary); text-decoration: none; font-weight: 600;">&larr; Back
                        to Directory</a>
                    <h1 style="margin-top: 20px;">Register New Staff</h1>
                </header>

                <section class="card" style="max-width: 800px;">
                    <form action="/staff/add" method="POST" class="enroll-form" enctype="multipart/form-data">
                        <div class="grid-2">
                            <div class="form-group">
                                <label>First Name</label>
                                <input type="text" name="first_name" placeholder="Enter first name" required class="form-control">
                            </div>
                            <div class="form-group">
                                <label>Last Name</label>
                                <input type="text" name="last_name" placeholder="Enter last name" required class="form-control">
                            </div>
                            <div class="form-group">
                                <label>Staff ID (MANDATORY LOGIN ID)</label>
                                <input type="text" name="staff_id" placeholder="e.g. tcher01, admin_js" required class="form-control" style="text-transform: lowercase;">
                                <small class="text-muted">This will be used for login. Must be unique.</small>
                            </div>
                            <div class="form-group">
                                <label>System Access Role</label>
                                <select name="role" required class="form-control">
                                    <option value="">-- Select Access --</option>
                                    <option value="Admin">Administrator (Full Access)</option>
                                    <option value="Teacher">Academic Staff (Class/Subject Access)</option>
                                    <option value="Staff">Non-Academic Staff (Restricted Access)</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Designation / Title</label>
                                <input type="text" name="designation" placeholder="e.g. Class Teacher, Registrar" required class="form-control">
                            </div>
                            <div class="form-group">
                                <label>Profile Photo (Website)</label>
                                <input type="file" name="avatar_image" class="form-control" accept="image/*">
                                <small class="text-muted">Photo to display publicly on the school website.</small>
                            </div>
                        </div>

                        <div class="form-group" style="margin-top: 20px;">
                            <label>Public Bio</label>
                            <textarea name="public_bio" class="form-control" rows="3" placeholder="A brief bio visible on the public school website..."></textarea>
                        </div>

                        <div class="form-group" style="margin-top: 15px; display: flex; align-items: center; gap: 12px;">
                            <input type="checkbox" name="show_on_website" id="show_on_website" style="width: 18px; height: 18px;">
                            <label for="show_on_website" style="margin: 0; cursor: pointer; font-weight: 600;">Show on Public Website (Faculty Section)</label>
                        </div>

                        <div class="alert alert-info" style="margin-top: 20px;">
                            <i class="bi bi-info-circle-fill"></i>
                            <strong>Note:</strong> Default password for new staff is <code>[StaffID]123</code>. They should change it after first login.
                        </div>

                        <div style="margin-top: 30px; display: flex; gap: 10px;">
                            <button type="submit" class="btn btn-primary">Register Staff Member</button>
                            <a href="/staff" class="btn btn-outline">Cancel</a>
                        </div>
                    </form>
                </section>
            </main>
    </div>

    <%- include('../partials/footer') %>