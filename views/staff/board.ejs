<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
    <div class="navbar">
        <div class="nav-title">
            <span class="staff-greeting">Assigned Class Board</span>
        </div>
        <div class="user-info">
            <span><%= staff.first_name %> <%= staff.last_name %></span>
            <div class="user-avatar"><i class="bi bi-person"></i></div>
            <a href="/auth/logout" class="btn btn-outline" style="margin-left: 10px;"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </div>
    </div>

    <% if(error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <% if(success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (classes && classes.length > 0) { %>
        <div class="card mb-4 mt-3">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Class Board</h3>
            </div>
            <div class="card-body">
                <h4>Create a New Post</h4>
                <form action="/staff/board/post" method="POST" enctype="multipart/form-data" class="mt-3 form-group">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label>Target Class</label>
                            <select name="class_id" class="form-control" required>
                                <% classes.forEach(c => { %>
                                    <option value="<%= c.id %>"><%= c.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label>Target Subject (Optional)</label>
                            <select name="subject_id" class="form-control">
                                <option value="">-- None --</option>
                                <% subjects.forEach(s => { %>
                                    <option value="<%= s.id %>"><%= s.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label>Target Student (Optional)</label>
                            <select name="student_id" class="form-control" id="studentSelect">
                                <option value="">-- Whole Class --</option>
                                <% students.forEach(st => { %>
                                    <option value="<%= st.id %>" data-class="<%= st.class_id %>"><%= st.first_name %> <%= st.last_name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label>Post Type</label>
                            <select name="post_type" class="form-control" required id="postTypeSelect">
                                <option value="Announcement">Announcement</option>
                                <option value="Assignment">Assignment</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3" id="dueDateContainer" style="display: none;">
                            <label>Due Date</label>
                            <input type="date" name="due_date" class="form-control">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Title</label>
                        <input type="text" name="title" class="form-control" required placeholder="e.g. Read Chapter 4">
                    </div>
                        <textarea name="content" class="form-control" rows="4" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label>Attachment (Optional)</label>
                        <input type="file" name="attachment" class="form-control">
                        <small class="text-muted">Upload PDFs, Images, or Documents for assignments.</small>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Submit Post</button>
                </form>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h3 class="mb-0">Recent Posts</h3>
            </div>
            <div class="card-body">
                <% if (posts && posts.length > 0) { %>
                    <div class="list-group">
                        <% posts.forEach(post => { %>
                            <div class="list-group-item list-group-item-action flex-column align-items-start mb-3" style="border: 1px solid #e2e8f0; border-radius: 8px;">
                                <div class="d-flex w-100 justify-content-between">
                                    <h5 class="mb-1">
                                        <% if(post.post_type === 'Assignment') { %>
                                            <span class="badge bg-danger">Assignment</span>
                                        <% } else { %>
                                            <span class="badge bg-info">Announcement</span>
                                        <% } %>
                                        <%= post.title %> 
                                        <span class="text-muted" style="font-size: 0.85rem;">
                                            (To: <%= post.class_name %><%= post.subject_name ? ' - ' + post.subject_name : '' %>
                                            <% if(post.student_fname) { %>
                                                <strong class="text-primary">| ONLY: <%= post.student_fname %> <%= post.student_lname %></strong>
                                            <% } %>
                                            )
                                        </span>
                                    </h5>
                                    <small><%= new Date(post.created_at).toLocaleDateString() %></small>
                                </div>
                                <p class="mb-1 mt-2" style="white-space: pre-wrap;"><%= post.content %></p>
                                <% if(post.post_type === 'Assignment' && post.due_date) { %>
                                    <small class="text-danger">Due Date: <%= new Date(post.due_date).toLocaleDateString() %></small>
                                <% } %>
                                <% if(post.attachment_path) { %>
                                    <div class="mt-2">
                                        <a href="/uploads/<%= post.attachment_path %>" target="_blank" class="btn btn-sm btn-light">
                                            <i class="bi bi-paperclip"></i> View Attachment
                                        </a>
                                    </div>
                                <% } %>
                                <form action="/staff/board/post/delete/<%= post.id %>" method="POST" class="mt-2" style="text-align: right;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this post?')">Delete</button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p class="text-muted">No posts found.</p>
                <% } %>
            </div>
        </div>
    <% } else { %>
        <div class="alert alert-warning mt-4">
            You are not assigned to any classes. Please contact the administrator.
        </div>
    <% } %>

</div>

<script>
    document.getElementById('postTypeSelect').addEventListener('change', function() {
        if(this.value === 'Assignment') {
            document.getElementById('dueDateContainer').style.display = 'block';
        } else {
            document.getElementById('dueDateContainer').style.display = 'none';
        }
    });

    const classSelect = document.querySelector('select[name="class_id"]');
    const studentSelect = document.getElementById('studentSelect');
    
    function filterStudents() {
        const classId = classSelect.value;
        const options = studentSelect.querySelectorAll('option[data-class]');
        options.forEach(opt => {
            if(opt.getAttribute('data-class') === classId) {
                opt.style.display = 'block';
            } else {
                opt.style.display = 'none';
            }
        });
        // optional: auto-reset if selected student is not in new class
        if(studentSelect.options[studentSelect.selectedIndex] && studentSelect.options[studentSelect.selectedIndex].style.display === 'none') {
            studentSelect.value = '';
        }
    }
    
    classSelect.addEventListener('change', filterStudents);
    filterStudents();
</script>

<%- include('../partials/footer') %>
