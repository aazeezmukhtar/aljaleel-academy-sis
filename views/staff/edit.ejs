<%- include('../partials/header') %>

    <div class="dashboard-container">
        <%- include('../partials/sidebar') %>

            <main class="main-content">
                <header class="content-header">
                    <div>
                        <h1>Edit Staff</h1>
                        <p class="text-muted">Update profile for <%= member.first_name %> <%= member.last_name %></p>
                    </div>
                    <a href="/staff/view/<%= member.id %>" class="btn btn-outline">
                        <i class="bi bi-arrow-left"></i> Back to Profile
                    </a>
                </header>

                <div class="card" style="max-width: 700px; margin: 0 auto; padding: 30px;">
                    <form action="/staff/update/<%= member.id %>" method="POST" enctype="multipart/form-data">

                        <div class="grid-2">
                            <div class="form-group">
                                <label>First Name</label>
                                <input type="text" name="first_name" class="form-control" value="<%= member.first_name %>" required>
                            </div>
                            <div class="form-group">
                                <label>Last Name</label>
                                <input type="text" name="last_name" class="form-control" value="<%= member.last_name %>" required>
                            </div>
                            <div class="form-group">
                                <label>Staff ID</label>
                                <input type="text" name="staff_id" class="form-control" value="<%= member.staff_id %>" required>
                            </div>
                            <div class="form-group">
                                <label>Designation</label>
                                <input type="text" name="designation" class="form-control" value="<%= member.designation %>" placeholder="e.g. Senior Teacher">
                            </div>
                            <div class="form-group">
                                <label>Role</label>
                                <select name="role" class="form-control" required>
                                    <option value="Teacher" <%=member.role==='Teacher' ? 'selected' : '' %>>Teacher</option>
                                    <option value="Admin" <%=member.role==='Admin' ? 'selected' : '' %>>Admin</option>
                                    <option value="Bursar" <%=member.role==='Bursar' ? 'selected' : '' %>>Bursar</option>
                                    <option value="Principal" <%=member.role==='Principal' ? 'selected' : '' %>>Principal</option>
                                    <option value="Staff" <%=member.role==='Staff' ? 'selected' : '' %>>Staff</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Status</label>
                                <select name="status" class="form-control" required>
                                    <option value="active" <%=member.status==='active' ? 'selected' : '' %>>Active</option>
                                    <option value="suspended" <%=member.status==='suspended' ? 'selected' : '' %>>Suspended</option>
                                    <option value="inactive" <%=member.status==='inactive' ? 'selected' : '' %>>Inactive</option>
                                </select>
                            </div>
                        </div>

                        <div style="margin-top: 30px; display: flex; gap: 10px;">
                            <button type="submit" class="btn btn-primary" style="flex: 1;">Update Staff Profile</button>
                            <a href="/staff/view/<%= member.id %>" class="btn btn-outline" style="flex: 1; text-align: center;">Cancel</a>
                        </div>
                    </form>
                </div>
            </main>
    </div>

    <%- include('../partials/footer') %>