                                    style="position: relative; height: 120px; border: 2px dashed #d1d5db; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #f9fafb; transition: all 0.2s ease;">
                                    <i class="bi bi-cloud-arrow-up"
                                        style="font-size: 2rem; color: #9ca3af; margin-bottom: 10px;"></i>
                                    <span style="color: #6b7280; font-weight: 500;">Click to upload file</span>
                                    <input type="file" name="studentFile" id="studentFile" accept=".xlsx,.xls" required
                                        style="position: absolute; width: 100%; height: 100%; opacity: 0; cursor: pointer;">
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary" style="width: 100%; height: 48px;">
                                <i class="bi bi-upload"></i> Import Students
                            </button>
                        </form>

                        <!-- Status Section (Hidden by default) -->
                        <div id="statusSection"
                            style="margin-top: 30px; display: none; padding-top: 20px; border-top: 1px solid #eee;">
                            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                                <div id="statusIcon" style="font-size: 1.5rem;"></div>
                                <h4 id="statusTitle" style="margin: 0;">Processing...</h4>
                            </div>
                            <div id="statusMessage"></div>

                            <div id="errorList"
                                style="margin-top: 15px; background: #fef2f2; padding: 15px; border-radius: 8px; display: none;">
                            </div>
                            <div id="duplicateList"
                                style="margin-top: 15px; background: #fff7ed; padding: 15px; border-radius: 8px; display: none;">
                            </div>
                        </div>
                    </section>

