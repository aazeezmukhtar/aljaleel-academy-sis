    <script>
        document.getElementById('importForm').onsubmit = async (e) => {
            e.preventDefault();

            const formData = new FormData(e.target);

            const statusSection = document.getElementById('statusSection');
            const statusTitle = document.getElementById('statusTitle');
            const statusIcon = document.getElementById('statusIcon');
            const statusMessage = document.getElementById('statusMessage');
            const errorList = document.getElementById('errorList');
            const duplicateList = document.getElementById('duplicateList');
            const submitBtn = document.querySelector('button[type="submit"]');

            statusSection.style.display = 'block';
            statusIcon.innerHTML = '<div class="spinner-border" style="width: 24px; height: 24px; border: 3px solid #ddd; border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite;"></div>';
            statusTitle.innerText = 'Importing...';
            statusMessage.innerHTML = '<p class="text-muted">Please wait while we process your file...</p>';
            errorList.style.display = 'none';
            duplicateList.style.display = 'none';
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Processing...';

            // Add spinner css if not exists
            if (!document.getElementById('spinner-style')) {
                const style = document.createElement('style');
                style.id = 'spinner-style';
                style.innerHTML = '@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }';
                document.head.appendChild(style);
            }

            try {
                const response = await fetch('/students/bulk-import', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    statusIcon.innerHTML = '<i class="bi bi-check-circle-fill" style="color: var(--success);"></i>';
                    statusTitle.innerText = 'Import Successful';
                    statusTitle.style.color = 'var(--success)';
                    statusMessage.innerHTML = `<p style="color: var(--success); font-weight: 600;">${result.message}</p>`;

                    document.getElementById('importForm').reset();
                    submitBtn.innerHTML = '<i class="bi bi-check"></i> Done';

                    setTimeout(() => {
                        window.location.href = '/students';
                    }, 2000);
                } else {
                    statusIcon.innerHTML = '<i class="bi bi-x-circle-fill" style="color: var(--danger);"></i>';
                    statusTitle.innerText = 'Import Failed';
                    statusTitle.style.color = 'var(--danger)';
                    statusMessage.innerHTML = `<p style="color: var(--danger); font-weight: 600;">${result.message}</p>`;

                    if (result.errors && result.errors.length > 0) {
                        errorList.style.display = 'block';
                        errorList.innerHTML = '<h5 style="color: var(--danger); margin-bottom: 10px;">Validation Errors:</h5><ul style="color: var(--danger); margin: 0; padding-left: 20px;">';
                        result.errors.forEach(err => {
                            errorList.innerHTML += `<li>${err}</li>`;
                        });
                        errorList.innerHTML += '</ul>';
                    }

                    if (result.duplicates && result.duplicates.length > 0) {
                        duplicateList.style.display = 'block';
                        duplicateList.innerHTML = '<h5 style="color: #c2410c; margin-bottom: 10px;">Duplicate Student IDs:</h5><ul style="color: #c2410c; margin: 0; padding-left: 20px;">';
                        result.duplicates.forEach(dup => {
                            duplicateList.innerHTML += `<li>Row ${dup.row}: ${dup.message}</li>`;
                        });
                        duplicateList.innerHTML += '</ul>';
                    }

                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Try Again';
                }
            } catch (err) {
                console.error(err);
                statusIcon.innerHTML = '<i class="bi bi-exclamation-triangle-fill" style="color: var(--danger);"></i>';
                statusTitle.innerText = 'Network Error';
                statusMessage.innerHTML = '<p style="color: var(--danger);">A network error occurred. Please try again.</p>';
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Try Again';
            }
        };
    </script>