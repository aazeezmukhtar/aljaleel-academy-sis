<%- include('../partials/header') %>

    <div class="dashboard-container">
        <%- include('../partials/sidebar') %>

            <!-- Main Content -->
            <main class="main-content">
                <header class="content-header"
                    style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
                    <div>
                        <h1>Student Directory</h1>
                        <p class="text-muted">Manage and enroll students at <%= school.school_name %>
                        </p>
                    </div>
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <a href="/students/bulk-import" class="btn btn-outline" style="border-style: dashed; flex: 1; min-width: 120px; text-align: center;">
                            <i class="bi bi-file-earmark-spreadsheet"></i> Bulk Import
                        </a>
                        <a href="/students/enroll" class="btn btn-primary" style="flex: 1; min-width: 120px; text-align: center;">
                            <i class="bi bi-person-plus"></i> Enroll Student
                        </a>
                    </div>
                </header>

                <div class="card" style="margin-bottom: 30px;">
                    <form id="filter-form" action="/students" method="GET" style="display: flex; flex-wrap: wrap; gap: 12px; align-items: flex-end;">
                        <div style="flex: 1; min-width: 180px; position: relative;">
                            <i class="bi bi-search"
                                style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #9ca3af;"></i>
                            <input type="text" id="search-input" name="search" placeholder="Search students..."
                                value="<%= filters.search || '' %>" class="form-control" style="padding-left: 40px;">
                        </div>
                        <% if (typeof user !== 'undefined' && user && user.role === 'Admin') { %>
                            <div style="flex: 1; min-width: 140px;">
                                <select id="class-filter" name="class_id" class="form-control">
                                    <option value="">All Classes</option>
                                    <% if (typeof classes !== 'undefined' && classes) { classes.forEach(cls => { %>
                                        <option value="<%= cls.id %>" <%= filters.class_id == cls.id ? 'selected' : '' %>><%= cls.name %></option>
                                    <% }); } %>
                                </select>
                            </div>
                        <% } %>
                        <button type="submit" class="btn btn-primary" style="flex-shrink: 0; display: none;">Search</button>
                    </form>
                </div>

                <div class="table-container student-mobile-cards">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Student Name</th>
                                <th>Student ID</th>
                                <th>Gender</th>
                                <th>Class</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (students.length> 0) { %>
                                <% students.forEach(student=> { %>
                                    <tr class="student-row" data-class-ids="<%= student.enrolled_class_ids %>" data-search-text="<%= (student.first_name + ' ' + student.last_name + ' ' + (student.admission_number || '')).toLowerCase() %>">
                                        <td data-label="Name">
                                            <div style="display: flex; align-items: center; gap: 15px;">
                                                <div
                                                    style="width: 44px; height: 44px; background: #f3f4f6; border-radius: 10px; overflow: hidden; display: flex; align-items: center; justify-content: center; border: 2px solid #fff; box-shadow: var(--shadow-sm);">
                                                    <% if (student.passport_photo_path) { %>
                                                        <img src="<%= student.passport_photo_path %>" alt="Photo"
                                                            style="width: 100%; height: 100%; object-fit: cover;">
                                                        <% } else { %>
                                                            <i class="bi bi-person-fill"
                                                                style="color: #9ca3af; font-size: 1.25rem;"></i>
                                                            <% } %>
                                                </div>
                                                <span
                                                    style="font-weight: 600; font-size: 1rem; color: var(--text-primary);">
                                                    <%= student.first_name %> <%= student.last_name %>
                                                </span>
                                            </div>
                                        </td>
                                        <td data-label="ID">
                                            <span
                                                style="font-family: monospace; background: #f9fafb; padding: 2px 6px; border-radius: 4px; border: 1px solid #e5e7eb;">
                                                <%= student.admission_number || 'PENDING' %>
                                            </span>
                                        </td>
                                        <td data-label="Gender">
                                            <%= student.gender %>
                                        </td>
                                        <td data-label="Class">
                                            <% if (student.class_name) { %>
                                                <span class="badge"
                                                    style="background: #e0e7ff; color: #4338ca; padding: 4px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: 500;">
                                                    <%= student.class_name %>
                                                </span>
                                                <% } else { %>
                                                    <span class="text-muted">Unassigned</span>
                                                    <% } %>
                                        </td>
                                        <td data-label="Status">
                                            <% if (student.status==='active' ) { %>
                                                <span
                                                    style="color: var(--success); font-weight: 600; display: inline-flex; align-items: center; gap: 4px;">
                                                    <i class="bi bi-check-circle-fill" style="font-size: 0.8rem;"></i>
                                                    Active
                                                </span>
                                                <% } else { %>
                                                    <span
                                                        style="color: var(--danger); font-weight: 600; display: inline-flex; align-items: center; gap: 4px;">
                                                        <i class="bi bi-x-circle-fill" style="font-size: 0.8rem;"></i>
                                                        <%= student.status %>
                                                    </span>
                                                    <% } %>
                                        </td>
                                        <td data-label="Action">
                                            <a href="/students/view/<%= student.id %>" class="btn btn-outline"
                                                style="padding: 4px 12px; font-size: 0.85rem;">
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <tr id="empty-state-row" style="display: none;">
                                            <td colspan="6" style="text-align: center; padding: 60px;">
                                                <div style="color: var(--text-muted); margin-bottom: 15px;">
                                                    <i class="bi bi-search"
                                                        style="font-size: 2rem; opacity: 0.5;"></i>
                                                </div>
                                                <p>No students found matching your criteria.</p>
                                            </td>
                                        </tr>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="6" style="text-align: center; padding: 60px;">
                                                    <div style="color: var(--text-muted); margin-bottom: 15px;">
                                                        <i class="bi bi-search"
                                                            style="font-size: 2rem; opacity: 0.5;"></i>
                                                    </div>
                                                    <p>No students found in directory.</p>
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination could go here -->
            </main>
    </div>

    <style>
        @media (max-width: 768px) {
            .student-mobile-cards table,
            .student-mobile-cards tbody,
            .student-mobile-cards tr,
            .student-mobile-cards td {
                display: block !important;
                width: 100% !important;
                box-sizing: border-box !important;
            }
            .student-mobile-cards thead { display: none !important; }
            
            .student-mobile-cards tr {
                padding: 16px !important;
                border: 1px solid #e2e8f0 !important;
                border-radius: 16px !important;
                margin-bottom: 16px !important;
                background: white !important;
                display: grid !important;
                grid-template-columns: 1fr auto !important;
                grid-template-rows: auto auto auto !important;
                gap: 12px 8px !important;
                box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05) !important;
            }
            
            .student-mobile-cards td {
                border: none !important;
                padding: 0 !important;
                background: transparent !important;
            }
            
            .student-mobile-cards td:before { display: none !important; }
            
            /* 1. Name cell - top left spanning */
            .student-mobile-cards td[data-label="Name"] {
                grid-column: 1 / 3;
                grid-row: 1;
                border-bottom: 1px solid #f1f5f9 !important;
                padding-bottom: 12px !important;
            }
            
            /* 2. ID and Class inline */
            .student-mobile-cards td[data-label="ID"] {
                grid-column: 1;
                grid-row: 2;
                display: flex !important;
                align-items: center;
            }
            
            .student-mobile-cards td[data-label="Class"] {
                grid-column: 2;
                grid-row: 2;
                display: flex !important;
                justify-content: flex-end;
                align-items: center;
            }
            
            /* 3. Status and Action inline */
            .student-mobile-cards td[data-label="Status"] {
                grid-column: 1;
                grid-row: 3;
                display: flex !important;
                align-items: center;
            }
            
            .student-mobile-cards td[data-label="Action"] {
                grid-column: 2;
                grid-row: 3;
                display: flex !important;
                justify-content: flex-end;
                align-items: center;
            }
            
            /* Action button full width on very small screens, but we keep it small here */
            .student-mobile-cards td[data-label="Action"] .btn {
                padding: 6px 16px !important;
                border-radius: 8px !important;
            }

            /* Hide Gender to save vertical space */
            .student-mobile-cards td[data-label="Gender"] {
                display: none !important;
            }
            
            /* Format labels for remaining items to give context without bulky table headers */
            .student-mobile-cards td[data-label="ID"]::before {
                content: 'ID:';
                display: inline-block !important;
                font-size: 0.75rem;
                color: #94a3b8;
                margin-right: 6px;
                font-weight: 700;
            }
        }
    </style>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('search-input');
        const classFilter = document.getElementById('class-filter');
        const rows = document.querySelectorAll('.student-row');
        const emptyState = document.getElementById('empty-state-row');

        function filterTable() {
            const searchText = searchInput ? searchInput.value.toLowerCase().trim() : '';
            const selectedClassId = classFilter ? classFilter.value : '';

            let visibleCount = 0;

            rows.forEach(row => {
                const rowSearchText = row.getAttribute('data-search-text') || '';
                const rowClassIds = (row.getAttribute('data-class-ids') || '').split(',');

                const matchesSearch = searchText === '' || rowSearchText.includes(searchText);
                const matchesClass = selectedClassId === '' || rowClassIds.includes(selectedClassId);

                if (matchesSearch && matchesClass) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            if (emptyState) {
                if (visibleCount === 0 && rows.length > 0) {
                    emptyState.style.display = '';
                } else {
                    emptyState.style.display = 'none';
                }
            }
        }

        if (searchInput) {
            searchInput.addEventListener('input', filterTable);
        }
        if (classFilter) {
            classFilter.addEventListener('change', filterTable);
        }

        // Run initial filter in case query params were populated
        filterTable();

        // Prevent form submission since it is now realtime
        const filterForm = document.getElementById('filter-form');
        if (filterForm) {
            filterForm.addEventListener('submit', function(e) {
                e.preventDefault();
                filterTable();
            });
        }
    });
    </script>

    <%- include('../partials/footer') %>